# Gyre Configuration
#
# Copy this file to ~/.gyre/.env and edit as needed.
# Priority: env var > config.toml > database settings > defaults.
#
# For zero-config startup: just have Claude Code installed (or set ANTHROPIC_API_KEY).
# Default backend is Anthropic + libSQL — no database setup required.

# ─── Database ────────────────────────────────────────────────────────
# Default: libsql (zero-config, creates ~/.gyre/gyre.db automatically)
# DATABASE_BACKEND=libsql
# LIBSQL_PATH=~/.gyre/gyre.db           # default path for embedded libSQL
# LIBSQL_URL=libsql://your-db.turso.io  # optional: Turso cloud sync
# LIBSQL_AUTH_TOKEN=your-token           # required when LIBSQL_URL is set

# PostgreSQL (for production deployments)
# DATABASE_BACKEND=postgres
# DATABASE_URL=postgres://localhost/gyre
# DATABASE_POOL_SIZE=10

# ─── LLM Provider ───────────────────────────────────────────────────
# Default: anthropic (auto-detects Claude Code OAuth or ANTHROPIC_API_KEY)
# LLM_BACKEND=anthropic
# Possible values: anthropic, openai, ollama, openai_compatible, tinfoil

# === Anthropic (default) ===
# Auto-detects your Claude.ai subscription via Claude Code's OAuth token.
# That token is short-lived; Gyre refreshes it automatically at startup and
# you can refresh on demand with `gyre auth login` (check it with
# `gyre auth status`). Setting ANTHROPIC_API_KEY below overrides all of that
# and is the most reliable option for an always-on agent.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
#
# Advanced — override Claude Code's OAuth endpoints (rarely needed; a wrong
# value just falls back to a guided `gyre auth login` prompt):
# CLAUDE_OAUTH_CLIENT_ID=...
# CLAUDE_OAUTH_TOKEN_URL=https://console.anthropic.com/v1/oauth/token

# === OpenAI ===
# LLM_BACKEND=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# === Ollama (local) ===
# LLM_BACKEND=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434   # default

# === OpenAI-compatible (LM Studio, vLLM, OpenRouter, etc.) ===
# LLM_BACKEND=openai_compatible
# LLM_MODEL=llama-3.2-3b-instruct-q4_K_M
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=sk-...                        # optional for local servers

# === OpenRouter (via OpenAI-compatible) ===
# LLM_BACKEND=openai_compatible
# LLM_MODEL=anthropic/claude-sonnet-4
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-...

# === Tinfoil (private inference) ===
# LLM_BACKEND=tinfoil
# TINFOIL_API_KEY=...
# TINFOIL_MODEL=claude-sonnet-4-5-20250929

# ─── Resilience ──────────────────────────────────────────────────────
# Circuit breaker (default: enabled)
# RESILIENCE_CIRCUIT_BREAKER_ENABLED=true
# RESILIENCE_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# RESILIENCE_CIRCUIT_BREAKER_RESET_TIMEOUT_SECS=30

# Response cache (default: disabled for main provider, enabled for cheap provider)
# RESILIENCE_RESPONSE_CACHE_ENABLED=false
# RESILIENCE_RESPONSE_CACHE_TTL_SECS=3600
# RESILIENCE_RESPONSE_CACHE_MAX_ENTRIES=1000

# Failover (default: disabled, requires fallback backend)
# RESILIENCE_FAILOVER_ENABLED=false
# RESILIENCE_FAILOVER_FALLBACK_BACKEND=ollama
# RESILIENCE_FAILOVER_FALLBACK_MODEL=llama3.2
# RESILIENCE_FAILOVER_FALLBACK_BASE_URL=http://localhost:11434
# RESILIENCE_FAILOVER_COOLDOWN_SECS=60

# ─── Channels ────────────────────────────────────────────────────────
# CLI is always enabled

# Slack Bot (optional)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_SIGNING_SECRET=...

# Telegram Bot (optional)
# TELEGRAM_BOT_TOKEN=...

# HTTP Webhook Server (optional)
# HTTP_HOST=0.0.0.0
# HTTP_PORT=8080
# HTTP_WEBHOOK_SECRET=your-webhook-secret

# ─── Agent Settings ──────────────────────────────────────────────────
# AGENT_NAME=gyre
# AGENT_MAX_PARALLEL_JOBS=5
# AGENT_JOB_TIMEOUT_SECS=3600
# AGENT_STUCK_THRESHOLD_SECS=300
# AGENT_USE_PLANNING=true

# Self-repair settings
# SELF_REPAIR_CHECK_INTERVAL_SECS=60
# SELF_REPAIR_MAX_ATTEMPTS=3

# ─── Heartbeat ───────────────────────────────────────────────────────
# HEARTBEAT_ENABLED=false
# HEARTBEAT_INTERVAL_SECS=1800
# HEARTBEAT_NOTIFY_CHANNEL=cli
# HEARTBEAT_NOTIFY_USER=default

# ─── Embeddings ──────────────────────────────────────────────────────
# EMBEDDING_ENABLED=false
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-...                     # required for OpenAI embeddings

# ─── Ambient memory recall ───────────────────────────────────────────
# Workspace memories auto-recalled into each turn's context (hybrid
# search on the incoming message). 0 disables; memory_search still works.
# MEMORY_AUTO_RECALL_TOP_K=3

# ─── Safety ──────────────────────────────────────────────────────────
# SAFETY_MAX_OUTPUT_LENGTH=100000
# SAFETY_INJECTION_CHECK_ENABLED=true

# ─── Egress policy ───────────────────────────────────────────────────
# Env overrides for [egress] in config.toml. Lists are comma-separated.
# Hosts are exact or "*.suffix" (subdomains only). Deny wins over allow.
# Mode governs unmatched hosts: observe (allow+audit, default) |
# enforce (deny+audit) | judge (LLM decides, fails closed).
#
# TRAP: an EMPTY env var reads as *unset* — EGRESS_ALLOW="" does NOT
# clear a TOML [egress] allow list; the TOML list stays active. To
# explicitly clear a list from the environment, set it to a bare comma:
# EGRESS_ALLOW=,   (same convention as the deny-all tool allowlist).
# Rules never carry ports — "host:8443" will never match; write "host".
# EGRESS_MODE=observe
# EGRESS_ALLOW=api.anthropic.com,api.openai.com,*.githubusercontent.com
# EGRESS_DENY=
# EGRESS_JUDGE_MAX_LATENCY_MS=3000

# ─── Routines ────────────────────────────────────────────────────────
# Hard deadline for a full_job routine's scheduled job. On expiry the job
# is cancelled and the run fails, releasing the routine concurrency slot.
# ROUTINES_FULL_JOB_TIMEOUT_SECS=3600

# ─── Logging ─────────────────────────────────────────────────────────
# RUST_LOG=gyre=debug,tower_http=debug

# WARNING: Replace all CHANGE_ME values before deploying.
# Do not use placeholder passwords in production.

# ── LLM Backend ──────────────────────────────────────────────────────
# Choose your LLM provider: "anthropic" or "openai"
LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=CHANGE_ME

# Uncomment for OpenAI instead:
# LLM_BACKEND=openai
# OPENAI_API_KEY=CHANGE_ME

# Model override (optional — sensible defaults per backend)
# LLM_MODEL=claude-sonnet-4-20250514

# ── Database ─────────────────────────────────────────────────────────
# "libsql" = embedded SQLite, zero dependencies (recommended for single-node)
# "postgres" = production PostgreSQL (requires a running server or docker-compose)
DATABASE_BACKEND=libsql

# PostgreSQL (only if DATABASE_BACKEND=postgres):
# DATABASE_URL=postgres://gyre:CHANGE_ME@localhost:5432/gyre

# libSQL local path (only if DATABASE_BACKEND=libsql):
# LIBSQL_PATH=~/.gyre/gyre.db

# ── Web Gateway ──────────────────────────────────────────────────────
GATEWAY_ENABLED=true
# 0.0.0.0 binds all interfaces (required inside Docker).
# Use 127.0.0.1 for local-only access outside Docker.
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=3000
# Bearer token for API access — generate with: openssl rand -hex 32
GATEWAY_AUTH_TOKEN=CHANGE_ME

# ── Agent ────────────────────────────────────────────────────────────
AGENT_NAME=gyre
CLI_ENABLED=false

# ── Embeddings (semantic memory search) ──────────────────────────────
EMBEDDING_ENABLED=false
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...           # reused from above if set
# EMBEDDING_MODEL=text-embedding-3-small

# ── Heartbeat (proactive periodic execution) ─────────────────────────
HEARTBEAT_ENABLED=false
# HEARTBEAT_INTERVAL_SECS=1800
# HEARTBEAT_NOTIFY_CHANNEL=tui

# ── Docker Sandbox ───────────────────────────────────────────────────
SANDBOX_ENABLED=false
# SANDBOX_IMAGE=gyre-worker:latest
# SANDBOX_MEMORY_LIMIT_MB=512
# SANDBOX_TIMEOUT_SECS=1800

# ── Claude Code mode (runs inside sandbox containers) ────────────────
# CLAUDE_CODE_ENABLED=false
# CLAUDE_CODE_MODEL=claude-sonnet-4-20250514
# CLAUDE_CODE_MAX_TURNS=50

# ── Routines (scheduled/reactive execution) ──────────────────────────
# ROUTINES_ENABLED=true
# ROUTINES_CRON_INTERVAL=60
# ROUTINES_MAX_CONCURRENT=3

# ── Resilience ───────────────────────────────────────────────────────
# Circuit breaker: trips after N consecutive LLM failures, resets after timeout.
# RESILIENCE_CIRCUIT_BREAKER_ENABLED=true
# RESILIENCE_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# RESILIENCE_CIRCUIT_BREAKER_RESET_TIMEOUT_SECS=60

# Response cache: caches identical LLM requests for TTL seconds.
# RESILIENCE_RESPONSE_CACHE_ENABLED=true
# RESILIENCE_RESPONSE_CACHE_TTL_SECS=300
# RESILIENCE_RESPONSE_CACHE_MAX_ENTRIES=100

# Failover: automatic fallback to a secondary LLM backend on failure.
# RESILIENCE_FAILOVER_ENABLED=false
# RESILIENCE_FAILOVER_FALLBACK_BACKEND=openai
# RESILIENCE_FAILOVER_FALLBACK_MODEL=gpt-4o
# RESILIENCE_FAILOVER_FALLBACK_API_KEY=sk-...
# RESILIENCE_FAILOVER_COOLDOWN_SECS=300

# ── Logging ──────────────────────────────────────────────────────────
RUST_LOG=gyre=info
